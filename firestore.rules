rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS COLLECTION (KEEP SECURE)
    match /users/{userId} {

      allow read: if request.auth != null && request.auth.uid == userId;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && !("premium" in request.resource.data)
        && !("expiresAt" in request.resource.data)
        && !("planType" in request.resource.data)
        && !("aiCredits" in request.resource.data);
    }

    // ✅ RESUMES COLLECTION (NEW FIX)
    match /resumes/{resumeId} {

      // Read only own resumes
      allow read: if request.auth != null 
        && request.auth.uid == resource.data.userId;

      // Create only if userId matches
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.userId;

      // Update/Delete only own resumes
      allow update, delete: if request.auth != null 
        && request.auth.uid == resource.data.userId;
    }
  }
}